# When BOTH of these are set, the app uses DynamoDB. Otherwise it uses an in-memory
# store (local dev only). The dashboard badge shows which backend is active.
AWS_REGION=us-east-1
DDB_TABLE=agentleash-cloud

# Credentials for an IAM principal with read/write on the table above.
# In Vercel, set these under Project Settings -> Environment Variables.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
